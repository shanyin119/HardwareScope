<Window x:Class="HardwareScope.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导出硬件信息" Width="680" Height="690"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Icon="/Assets/app-icon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#11192B"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#273454"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="17,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCE3F2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E6EBF7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,30,0"/>
        </Style>
    </Window.Resources>

    <Border Background="#0D1424" BorderBrush="#344362" BorderThickness="1" CornerRadius="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Grid Background="#111A2D" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center"><Image Source="/Assets/app-icon-final.png" Width="28" Height="28"/><TextBlock Text="导出硬件信息" Foreground="White" FontSize="17" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel>
                <Button Content="×" Width="48" Height="40" HorizontalAlignment="Right" Background="Transparent" FontSize="21" Click="Cancel_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="24,20,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="选择文件格式" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="生成的 Word 和 Excel 文件可直接用 Office 或兼容软件打开。" Foreground="#7E8AA5" Margin="0,5,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="#283654" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,14,0,20">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TextFormatRadio" Content="文本文件（.txt）" GroupName="Format" IsChecked="True"/>
                        <RadioButton x:Name="WordFormatRadio" Content="Word 文档（.docx）" GroupName="Format"/>
                        <RadioButton x:Name="ExcelFormatRadio" Content="Excel 表格（.xlsx）" GroupName="Format"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="选择导出内容" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="默认全部导出，也可以只保留需要的分类。" Foreground="#7E8AA5" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="全部选择" Padding="12,6" Margin="0,0,8,0" Click="SelectAll_Click"/>
                        <Button Content="全部取消" Padding="12,6" Click="SelectNone_Click"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="3" Background="{StaticResource PanelBrush}" BorderBrush="#283654" BorderThickness="1" CornerRadius="10" Padding="16,10" Margin="0,8,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SectionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="24,12,24,17">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Width="92" Background="#273454" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button Content="选择保存位置" Width="138" Background="#6479F3" FontWeight="SemiBold" Click="Export_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
