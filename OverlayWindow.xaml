<Window x:Class="HardwareScope.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ShowActivated="False" Topmost="True"
        Icon="/Assets/app-icon.ico"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseEnter="Window_MouseEnter" MouseLeave="Window_MouseLeave">
    <Border x:Name="OverlayCard" CornerRadius="14" BorderBrush="#4D6D83FF" BorderThickness="1"
            Padding="14,11" MinWidth="238" SnapsToDevicePixels="True" Cursor="SizeAll">
        <StackPanel>
            <DockPanel Margin="0,0,0,8">
                <TextBlock x:Name="ModeHintText" DockPanel.Dock="Right" Text="可拖动" Foreground="#6D83FF"
                           FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Ellipse Width="7" Height="7" Fill="#45E0B7" Margin="0,0,7,0"/>
                <TextBlock Text="别离检测工具 · 温度" Foreground="#9CA8C4" FontSize="10" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <StackPanel x:Name="ReadingsPanel"/>
        </StackPanel>
    </Border>
</Window>
